{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [2, "always", [
      "feat",
      "fix",
      "docs",
      "style",
      "refactor",
      "perf",
      "test",
      "chore",
      "revert",
      "ci",
      "build"
    ]],
    "scope-enum": [2, "always", [
      "gui",
      "hardware",
      "image_processing",
      "gcode",
      "optical",
      "build",
      "ci",
      "deps"
    ]]
  }
}
